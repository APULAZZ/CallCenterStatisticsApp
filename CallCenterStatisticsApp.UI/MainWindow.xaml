<Window x:Class="CallCenterStatisticsApp.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Call Center Statistics" Height="780" Width="1280"
        MinHeight="620" MinWidth="1024" WindowStartupLocation="CenterScreen" WindowState="Maximized" Background="{DynamicResource AppBackground}">
    <Window.Resources>
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Foreground" Value="#CBD5E1"/><Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/><Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="16,11"/><Setter Property="Margin" Value="10,2"/><Setter Property="FontSize" Value="14"/>
            <Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#243554"/></Trigger></Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition Width="244"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
        <Border Background="#15233D">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="26,28,16,22">
                    <TextBlock Text="MANGO" Foreground="#60A5FA" FontWeight="Bold" FontSize="12"/>
                    <TextBlock Text="Call Center" Foreground="White" FontWeight="SemiBold" FontSize="22" Margin="0,4,0,0"/>
                    <TextBlock Text="Статистика звонков" Foreground="#94A3B8" FontSize="12" Margin="0,3,0,0"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Top">
                    <Button Style="{StaticResource NavButton}" Content="▦   Обзор" Click="DashboardButton_Click"/>
                    <Button Style="{StaticResource NavButton}" Content="☎   Журнал звонков" Click="JournalButton_Click"/>
                    <Button Style="{StaticResource NavButton}" Content="◷   Статистика сотрудников" Click="EmployeeStatsButton_Click"/>
                    <Button Style="{StaticResource NavButton}" Content="◫   Статистика групп" Click="GroupStatsButton_Click"/>
                    <Button Style="{StaticResource NavButton}" Content="⇩   Импорт из Mango" Click="ImportButton_Click"/>
                    <Button Style="{StaticResource NavButton}" Content="▤   Гугл-таблички" Click="GoogleSheetsButton_Click"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,20">
                    <Separator Background="#2B3B58" Margin="20,8"/>
                    <Button Style="{StaticResource NavButton}" Content="⚙   Настройки API" Click="MangoApiTestButton_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions><RowDefinition Height="76"/><RowDefinition Height="*"/><RowDefinition Height="32"/></Grid.RowDefinitions>
            <Border Background="{DynamicResource AppSurface}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,0,0,1">
                <Grid Margin="30,0"><TextBlock x:Name="PageTitle" VerticalAlignment="Center" FontSize="20" FontWeight="SemiBold" Foreground="#172033"/><TextBlock Text="Mango Office" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="#64748B"/></Grid>
            </Border>
            <ContentControl x:Name="PageContent" Grid.Row="1" Margin="30,24"/>
            <Border Grid.Row="2" Background="{DynamicResource AppSurface}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,1,0,0"><TextBlock x:Name="StatusText" Margin="30,0" VerticalAlignment="Center" Foreground="{DynamicResource AppMutedText}" FontSize="12"/></Border>
            <Border x:Name="BusyOverlay" Grid.RowSpan="3" Background="#990F172A" Visibility="Collapsed">
                <Border Background="{DynamicResource AppSurface}" CornerRadius="10" Padding="26" Width="360" VerticalAlignment="Center" HorizontalAlignment="Center"><StackPanel><TextBlock x:Name="BusyMessageText" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource AppText}" TextAlignment="Center" TextWrapping="Wrap"/><ProgressBar IsIndeterminate="True" Height="8" Margin="0,18,0,0"/></StackPanel></Border>
            </Border>
        </Grid>
    </Grid>
</Window>
