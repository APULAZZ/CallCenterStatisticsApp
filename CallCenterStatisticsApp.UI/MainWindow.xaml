<Window x:Class="CallCenterStatisticsApp.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Call Center Statistics"
        Height="450"
        Width="700">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Call Center Statistics"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <WrapPanel>
                <Button Content="Импорт из MANGO"
                        Width="180"
                        Height="40"
                        Margin="0,0,10,10"
                        Click="ImportButton_Click"/>

                <Button Content="Статистика по сотрудникам"
                        Width="220"
                        Height="40"
                        Margin="0,0,10,10"
                        Click="EmployeeStatsButton_Click"/>

                <Button Content="Статистика по группам"
                        Width="200"
                        Height="40"
                        Margin="0,0,10,10"
                        Click="GroupStatsButton_Click"/>

                <Button Content="Тест MANGO API"
                        Width="180"
                        Height="40"
                        Margin="0,0,10,10"
                        Click="MangoApiTestButton_Click"/>

                <Button Content="Журнал звонков"
                        Width="180"
                        Height="40"
                        Margin="0,0,10,10"
                        Click="CallLogButton_Click"/>
                <Button Content="Обновить тематики"
                        Width="180"
                        Height="40"
                        Margin="0,0,10,10"
                        Click="TopicEnrichmentButton_Click"/>
            </WrapPanel>
        </StackPanel>
    </Grid>
</Window>