<Application x:Class="CallCenterStatisticsApp.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:CallCenterStatisticsApp.UI">
    <Application.Resources>
        <SolidColorBrush x:Key="AppBackground" Color="#F6F8FC"/>
        <SolidColorBrush x:Key="AppSurface" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="AppBorder" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="AppText" Color="#172033"/>
        <SolidColorBrush x:Key="AppMutedText" Color="#64748B"/>
    </Application.Resources>
</Application>
