<Window x:Class="CallCenterStatisticsApp.UI.TopicEnrichmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Обновление тематик звонков"
        Height="340"
        Width="560"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Обновление тематик звонков"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Количество звонков для обработки"
                       Margin="0,0,0,6"/>
            <TextBox x:Name="BatchSizeTextBox"
                     Width="120"
                     Text="50"
                     Margin="0,0,0,12"/>

            <TextBlock Text="Обрабатываются только звонки:"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6"/>

            <TextBlock Text="- у которых еще нет тематики"
                       Margin="0,0,0,2"/>

            <TextBlock Text="- у которых есть RecordingId"
                       Margin="0,0,0,2"/>

            <TextBlock Text="- по ним выполняется запрос в речевую аналитику MANGO"
                       Margin="0,0,0,2"/>
        </StackPanel>

        <Border Grid.Row="2"
                Margin="0,15,0,0"
                Padding="12"
                CornerRadius="8"
                BorderThickness="1"
                BorderBrush="#D0D7E2"
                Background="#F7F9FC">
            <StackPanel>
                <TextBlock Text="Статус"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6"/>

                <TextBlock x:Name="StatusTextBlock"
                           Text="Готово."
                           TextWrapping="Wrap"
                           Foreground="DarkBlue"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">
            <Button x:Name="BackButton"
                    Content="Назад"
                    Width="110"
                    Height="34"
                    Margin="0,0,10,0"
                    Click="BackButton_Click"/>

            <Button x:Name="RunButton"
                    Content="Обновить тематики"
                    Width="170"
                    Height="34"
                    Click="RunButton_Click"/>
        </StackPanel>
    </Grid>
</Window>