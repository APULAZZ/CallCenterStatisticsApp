<UserControl x:Class="CallCenterStatisticsApp.UI.Views.GroupStatisticsPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <TextBlock Text="Результаты по группам за выбранный период" Foreground="#64748B"/>
        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="16" Margin="0,14,0,18"><WrapPanel><StackPanel><TextBlock Text="Период" Foreground="#64748B" FontSize="12"/><StackPanel Orientation="Horizontal"><DatePicker x:Name="FromDatePicker" Width="140"/><TextBlock Text="—" Margin="8,0" VerticalAlignment="Center"/><DatePicker x:Name="ToDatePicker" Width="140"/></StackPanel></StackPanel><Button Content="Обновить" Click="RefreshButton_Click" Padding="18,7" Margin="16,17,0,0"/></WrapPanel></Border>
        <Border Grid.Row="2" Background="White" CornerRadius="10"><Grid><Grid.RowDefinitions><RowDefinition Height="42"/><RowDefinition Height="*"/></Grid.RowDefinitions><TextBlock x:Name="SummaryTextBlock" Text="Групп в отчёте: 0" VerticalAlignment="Center" Margin="18,0" FontWeight="SemiBold" Foreground="#334155"/><DataGrid x:Name="StatsDataGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" GridLinesVisibility="Horizontal" RowHeight="36"><DataGrid.Columns><DataGridTextColumn Header="Группа" Binding="{Binding GroupName}" Width="*"/><DataGridTextColumn Header="Входящие" Binding="{Binding IncomingCount}" Width="130"/><DataGridTextColumn Header="Пропущенные" Binding="{Binding IncomingMissedCount}" Width="145"/><DataGridTextColumn Header="Исходящие" Binding="{Binding OutgoingCount}" Width="130"/><DataGridTextColumn Header="Без ответа" Binding="{Binding OutgoingNoAnswerCount}" Width="130"/></DataGrid.Columns></DataGrid></Grid></Border>
    </Grid>
</UserControl>
