<UserControl x:Class="CallCenterStatisticsApp.UI.Views.TopicEnrichmentPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><StackPanel><TextBlock Text="Речевая аналитика" FontSize="26" FontWeight="SemiBold" Foreground="#172033"/><TextBlock Text="Запрашивает категории речевой аналитики Mango для записей разговора. Эти категории не являются темами обращений и не используются в столбце «Тематика» журнала." Foreground="#64748B" Margin="0,8,0,0" TextWrapping="Wrap"/></StackPanel><Border Grid.Row="1" Background="White" CornerRadius="10" Padding="26" Margin="0,24,0,0" MaxWidth="560" HorizontalAlignment="Left" VerticalAlignment="Top"><StackPanel><TextBlock Text="Количество записей" FontWeight="SemiBold"/><TextBox x:Name="BatchSizeTextBox" Text="50" Width="130" Margin="0,8,0,18" HorizontalAlignment="Left"/><Button x:Name="RunButton" Content="Обновить категории" Click="RunButton_Click" Padding="18,8" HorizontalAlignment="Left"/><Border Background="#F1F5F9" CornerRadius="6" Padding="12" Margin="0,20,0,0"><TextBlock x:Name="StatusTextBlock" Text="Готово к запуску." Foreground="#475569" TextWrapping="Wrap"/></Border></StackPanel></Border></Grid></UserControl>
