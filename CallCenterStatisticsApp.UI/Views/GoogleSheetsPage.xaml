<UserControl x:Class="CallCenterStatisticsApp.UI.Views.GoogleSheetsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Border Background="White" CornerRadius="10" Padding="18" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Рабочие таблицы КЦ" FontSize="20" FontWeight="SemiBold" Foreground="#172033"/>
                <TextBlock Text="Показатели рассчитываются по журналу звонков и тематикам MANGO. Графики и отсутствия будут добавлены здесь отдельно." Foreground="#64748B" Margin="0,5,0,16"/>
                <WrapPanel VerticalAlignment="Center">
                    <StackPanel Margin="0,0,8,0"><TextBlock Text="Месяц" Foreground="#64748B" Margin="0,0,0,4"/><ComboBox x:Name="MonthComboBox" Width="135" SelectionChanged="PeriodComboBox_SelectionChanged"/></StackPanel>
                    <StackPanel Margin="0,0,16,0"><TextBlock Text="Год" Foreground="#64748B" Margin="0,0,0,4"/><ComboBox x:Name="YearComboBox" Width="85" SelectionChanged="PeriodComboBox_SelectionChanged"/></StackPanel>
                    <StackPanel Margin="0,0,16,0"><TextBlock Text="Сотрудник" Foreground="#64748B" Margin="0,0,0,4"/><ComboBox x:Name="EmployeeComboBox" Width="220" SelectionChanged="EmployeeComboBox_SelectionChanged"/></StackPanel>
                    <Button Content="Обновить расчёт" Width="160" Height="32" Margin="0,22,0,0" Click="RefreshButton_Click"/>
                </WrapPanel>
            </StackPanel>
        </Border>
        <TabControl Grid.Row="1">
            <TabItem Header="Отчёты">
                <TabControl Margin="0,10,0,0">
                    <TabItem Header="Показатели по дням">
                        <ScrollViewer Margin="0,10,0,0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <Grid x:Name="DailyTableGrid" Background="White"/>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Header="ПЕРК по клиникам">
                        <ScrollViewer Margin="0,10,0,0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <Grid x:Name="ClinicTableGrid" Background="White"/>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Header="Графики и отсутствия">
                        <Grid Margin="0,10,0,0"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <WrapPanel Margin="0,0,0,12"><DatePicker x:Name="ManualDatePicker" Width="130" Margin="0,0,8,0"/><ComboBox x:Name="ManualTypeComboBox" Width="170" Margin="0,0,8,0"/><ComboBox x:Name="ManualEmployeeComboBox" Width="190" Margin="0,0,8,0"/><TextBox x:Name="ManualValueTextBox" Width="180" Margin="0,0,8,0" ToolTip="Смена, часы или комментарий"/><Button Content="Добавить" Width="100" Click="AddManualEntryButton_Click"/></WrapPanel>
                            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                <Grid x:Name="ManualTableGrid" Background="White"/>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>
                </TabControl>
            </TabItem>
            <TabItem Header="Сводные">
                <ContentControl x:Name="AnnualSummaryHost"/>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
