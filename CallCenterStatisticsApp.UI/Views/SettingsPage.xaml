<UserControl x:Class="CallCenterStatisticsApp.UI.Views.SettingsPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <StackPanel><TextBlock Text="Настройки" FontSize="26" FontWeight="SemiBold" Foreground="#172033"/><TextBlock Text="Параметры подключения читаются из appsettings.Local.json или переменных окружения." Foreground="#64748B" Margin="0,8,0,0"/></StackPanel>
        <StackPanel Grid.Row="1" Margin="0,24,0,0" MaxWidth="640" HorizontalAlignment="Left"><Border Background="{DynamicResource AppSurface}" CornerRadius="10" Padding="24"><StackPanel><TextBlock Text="Mango Office API" FontSize="17" FontWeight="SemiBold"/><TextBlock x:Name="EndpointTextBlock" Foreground="#64748B" Margin="0,10,0,0"/><TextBlock x:Name="CredentialsTextBlock" Foreground="#64748B" Margin="0,5,0,18"/><Button x:Name="TestButton" Content="Проверить подключение" Click="TestButton_Click" Padding="18,8" HorizontalAlignment="Left"/><TextBlock x:Name="StatusTextBlock" Text="Проверка ещё не выполнялась." Foreground="#475569" Margin="0,16,0,0" TextWrapping="Wrap"/><Separator Margin="0,20,0,16"/><TextBlock Text="Оформление" FontSize="17" FontWeight="SemiBold"/><Button x:Name="ThemeButton" Content="Включить тёмную тему" Click="ThemeButton_Click" Padding="18,8" HorizontalAlignment="Left" Margin="0,10,0,0"/></StackPanel></Border><Border Background="#EFF6FF" CornerRadius="10" Padding="18" Margin="0,16,0,0"><TextBlock Text="Чтобы изменить ключи Mango, отредактируйте appsettings.Local.json. Этот файл не должен попадать в систему контроля версий." Foreground="#1E3A8A" TextWrapping="Wrap"/></Border></StackPanel>
    </Grid>
</UserControl>
