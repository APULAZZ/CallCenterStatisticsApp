<UserControl x:Class="CallCenterStatisticsApp.UI.Views.JournalPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="ModernComboBoxStyle" TargetType="ComboBox"><Setter Property="Height" Value="34"/><Setter Property="Background" Value="White"/><Setter Property="Foreground" Value="#334155"/><Setter Property="BorderBrush" Value="#C9D7EA"/><Setter Property="BorderThickness" Value="1"/><Setter Property="Padding" Value="8,0"/><Setter Property="FontSize" Value="13"/></Style>
        <Style x:Key="ModernComboBoxItemStyle" TargetType="ComboBoxItem"><Setter Property="Padding" Value="10,7"/><Setter Property="Foreground" Value="#334155"/><Setter Property="Background" Value="White"/><Style.Triggers><Trigger Property="IsHighlighted" Value="True"><Setter Property="Background" Value="#EEF4FF"/></Trigger><Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#DBEAFE"/><Setter Property="FontWeight" Value="SemiBold"/></Trigger></Style.Triggers></Style>
        <Style x:Key="ActionButtonStyle" TargetType="Button"><Setter Property="Width" Value="118"/><Setter Property="Height" Value="34"/><Setter Property="Margin" Value="0,17,10,8"/><Setter Property="Background" Value="#FFFFFF"/><Setter Property="Foreground" Value="#475569"/><Setter Property="BorderBrush" Value="#C9D7EA"/><Setter Property="BorderThickness" Value="1"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Cursor" Value="Hand"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="7"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Border" Property="Background" Value="#EEF4FF"/><Setter TargetName="Border" Property="BorderBrush" Value="#93B4E8"/></Trigger><Trigger Property="IsPressed" Value="True"><Setter TargetName="Border" Property="Background" Value="#DDEAFE"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
    </UserControl.Resources>
    <Grid><Grid.RowDefinitions><RowDefinition Height="110"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="16" Margin="0,0,0,18"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="200"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Период" Foreground="#64748B" FontSize="12" Margin="0,0,0,5"/><ComboBox x:Name="PeriodComboBox" Style="{StaticResource ModernComboBoxStyle}" SelectedValuePath="Tag" SelectionChanged="PeriodComboBox_SelectionChanged" ItemContainerStyle="{StaticResource ModernComboBoxItemStyle}"><ComboBoxItem Content="Сегодня" Tag="Today"/><ComboBoxItem Content="Вчера" Tag="Yesterday"/><ComboBoxItem Content="Последние 7 дней" Tag="SevenDays"/><ComboBoxItem Content="Текущая неделя" Tag="Week"/><ComboBoxItem Content="Текущий месяц" Tag="Month"/><ComboBoxItem Content="Последние 30 дней" Tag="ThirtyDays"/><ComboBoxItem Content="Произвольный" Tag="Custom"/></ComboBox></StackPanel><StackPanel Grid.Column="2" x:Name="CustomPeriodPanel" Visibility="Hidden"><TextBlock Text="Произвольный период" Foreground="#64748B" FontSize="12" Margin="0,0,0,5"/><StackPanel Orientation="Horizontal"><DatePicker x:Name="FromDatePicker" Width="150" Height="34"/><TextBlock Text="—" VerticalAlignment="Center" Margin="10,0"/><DatePicker x:Name="ToDatePicker" Width="150" Height="34"/></StackPanel></StackPanel><TextBlock Grid.Column="2" x:Name="PeriodHintTextBlock" VerticalAlignment="Center" Foreground="#64748B" FontSize="14"/></Grid></Border>
        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="16" Margin="0,0,0,18"><WrapPanel VerticalAlignment="Center"><StackPanel Margin="0,0,12,8"><TextBlock Text="Сотрудник" Foreground="#64748B" FontSize="12"/><ComboBox x:Name="EmployeeComboBox" Width="170" DisplayMemberPath="Name" SelectedValuePath="Id" Style="{StaticResource ModernComboBoxStyle}" ItemContainerStyle="{StaticResource ModernComboBoxItemStyle}"/></StackPanel><StackPanel Margin="0,0,12,8"><TextBlock Text="Группа" Foreground="#64748B" FontSize="12"/><ComboBox x:Name="GroupComboBox" Width="160" DisplayMemberPath="Name" SelectedValuePath="Id" Style="{StaticResource ModernComboBoxStyle}" ItemContainerStyle="{StaticResource ModernComboBoxItemStyle}"/></StackPanel><StackPanel Margin="0,0,12,8"><TextBlock Text="Тематика" Foreground="#64748B" FontSize="12"/><ComboBox x:Name="TopicComboBox" Width="160" DisplayMemberPath="Name" SelectedValuePath="Id" Style="{StaticResource ModernComboBoxStyle}" ItemContainerStyle="{StaticResource ModernComboBoxItemStyle}"/></StackPanel><StackPanel Margin="0,0,12,8"><TextBlock Text="Тип звонка" Foreground="#64748B" FontSize="12"/><ComboBox x:Name="DirectionComboBox" Width="130" SelectedIndex="0" Style="{StaticResource ModernComboBoxStyle}" ItemContainerStyle="{StaticResource ModernComboBoxItemStyle}"><ComboBoxItem Content="Все"/><ComboBoxItem Content="Входящие"/><ComboBoxItem Content="Исходящие"/></ComboBox></StackPanel><StackPanel Margin="0,0,12,8"><TextBlock Text="Длительность" Foreground="#64748B" FontSize="12"/><ComboBox x:Name="DurationComboBox" Width="130" SelectedIndex="0" Style="{StaticResource ModernComboBoxStyle}" ItemContainerStyle="{StaticResource ModernComboBoxItemStyle}"><ComboBoxItem Content="Любая"/><ComboBoxItem Content="До минуты"/><ComboBoxItem Content="1–5 минут"/><ComboBoxItem Content="От 5 минут"/></ComboBox></StackPanel><StackPanel Margin="0,0,12,8"><TextBlock Text="Поиск" Foreground="#64748B" FontSize="12"/><TextBox x:Name="SearchTextBox" Width="180" Height="34" Padding="10,0"/></StackPanel><Button Content="Обновить" Style="{StaticResource ActionButtonStyle}" Click="RefreshButton_Click"/><Button Content="Сбросить" Style="{StaticResource ActionButtonStyle}" Click="ResetButton_Click"/></WrapPanel></Border>
        <Border Grid.Row="2" Background="White" CornerRadius="10" Padding="0"><Grid><Grid.RowDefinitions><RowDefinition Height="40"/><RowDefinition Height="*"/></Grid.RowDefinitions><TextBlock x:Name="SummaryTextBlock" Text="Записей: 0" FontWeight="SemiBold" VerticalAlignment="Center" Margin="18,0" Foreground="#334155"/><DataGrid x:Name="CallsDataGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal" RowHeight="34"><DataGrid.Columns><DataGridTextColumn Header="Дата и время" Binding="{Binding CallDateTime, StringFormat=dd.MM.yyyy HH:mm}" Width="145"/><DataGridTextColumn Header="Сотрудник" Binding="{Binding EmployeeName}" Width="*"/><DataGridTextColumn Header="Группа" Binding="{Binding GroupName}" Width="150"/><DataGridTextColumn Header="Телефон" Binding="{Binding ExternalPhoneNumber}" Width="140"/><DataGridTextColumn Header="Тематика" Binding="{Binding TopicName}" Width="180"/><DataGridTextColumn Header="Тип" Binding="{Binding DirectionDisplay}" Width="100"/><DataGridTextColumn Header="Длительность" Binding="{Binding DurationDisplay}" Width="105"/></DataGrid.Columns></DataGrid></Grid></Border>
    </Grid>
</UserControl>
