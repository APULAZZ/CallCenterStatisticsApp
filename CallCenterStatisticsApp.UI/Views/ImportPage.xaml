<UserControl x:Class="CallCenterStatisticsApp.UI.Views.ImportPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <StackPanel><TextBlock Text="Синхронизация с Mango Office" FontSize="26" FontWeight="SemiBold" Foreground="#172033"/><TextBlock Text="Данные будут получены из Mango и сохранены в локальную базу." Foreground="#64748B" Margin="0,8,0,0"/></StackPanel>
        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="26" Margin="0,24,0,0" MaxWidth="640" HorizontalAlignment="Left" VerticalAlignment="Top"><StackPanel><TextBlock Text="Период звонков" FontWeight="SemiBold" FontSize="16"/><StackPanel Orientation="Horizontal" Margin="0,10,0,18"><DatePicker x:Name="FromDatePicker" Width="160"/><TextBlock Text="—" VerticalAlignment="Center" Margin="10,0"/><DatePicker x:Name="ToDatePicker" Width="160"/></StackPanel><TextBlock Text="Дополнительно" FontWeight="SemiBold" FontSize="16"/><CheckBox x:Name="SyncEmployeesCheckBox" Content="Обновить сотрудников" IsChecked="True" Margin="0,10,0,4"/><CheckBox x:Name="SyncTopicsCheckBox" Content="Обновить справочник тематик" IsChecked="True" Margin="0,4,0,18"/><Button x:Name="RunButton" Content="Синхронизировать" Click="RunButton_Click" Padding="20,9" HorizontalAlignment="Left"/><Border Background="#F1F5F9" CornerRadius="6" Padding="12" Margin="0,20,0,0"><TextBlock x:Name="StatusTextBlock" Text="Готово к синхронизации." Foreground="#475569" TextWrapping="Wrap"/></Border></StackPanel></Border>
    </Grid>
</UserControl>
