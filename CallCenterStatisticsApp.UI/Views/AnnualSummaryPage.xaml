<UserControl x:Class="CallCenterStatisticsApp.UI.Views.AnnualSummaryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Border Background="White" CornerRadius="10" Padding="18" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Сводные таблицы КЦ" FontSize="20" FontWeight="SemiBold" Foreground="#172033"/>
                <TextBlock Text="Автоматические показатели берутся из журнала MANGO; отмеченные поля заполняются вручную и сохраняются на этом компьютере." Foreground="#64748B" Margin="0,5,0,16"/>
                <WrapPanel VerticalAlignment="Center">
                    <StackPanel Margin="0,0,14,0"><TextBlock Text="Год" Foreground="#64748B" Margin="0,0,0,4"/><ComboBox x:Name="SummaryYearComboBox" Width="90" SelectionChanged="PeriodSelectionChanged"/></StackPanel>
                    <StackPanel Margin="0,0,18,0"><TextBlock Text="Месяц для таблицы сотрудников" Foreground="#64748B" Margin="0,0,0,4"/><ComboBox x:Name="SummaryMonthComboBox" Width="150" SelectionChanged="PeriodSelectionChanged"/></StackPanel>
                    <Button Content="Обновить месяц из Mango" Width="190" Height="32" Margin="0,22,0,0" Click="RefreshButton_Click"/>
                </WrapPanel>
            </StackPanel>
        </Border>
        <TabControl Grid.Row="1">
            <TabItem Header="Общая сводная"><DataGrid x:Name="AnnualSummaryGrid" Margin="0,10,0,0" AutoGenerateColumns="False" CanUserAddRows="False" CellEditEnding="ManualGrid_CellEditEnding"/></TabItem>
            <TabItem Header="Показатели сотрудников"><DataGrid x:Name="EmployeeMetricsGrid" Margin="0,10,0,0" AutoGenerateColumns="False" CanUserAddRows="False" CellEditEnding="ManualGrid_CellEditEnding"/></TabItem>
            <TabItem Header="КЭФ сотрудников"><DataGrid x:Name="KefGrid" Margin="0,10,0,0" AutoGenerateColumns="False" CanUserAddRows="False" CellEditEnding="ManualGrid_CellEditEnding"/></TabItem>
            <TabItem Header="Запись к пришедшим"><DataGrid x:Name="AttendanceGrid" Margin="0,10,0,0" AutoGenerateColumns="False" CanUserAddRows="False" CellEditEnding="ManualGrid_CellEditEnding"/></TabItem>
            <TabItem Header="Баллы разговоров"><DataGrid x:Name="PhoneScoreGrid" Margin="0,10,0,0" AutoGenerateColumns="False" CanUserAddRows="False" CellEditEnding="ManualGrid_CellEditEnding"/></TabItem>
        </TabControl>
    </Grid>
</UserControl>
