<UserControl x:Class="CallCenterStatisticsApp.UI.Views.DashboardPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <StackPanel><TextBlock Text="Добро пожаловать" FontSize="28" FontWeight="SemiBold" Foreground="#172033"/><TextBlock Text="Рабочее пространство для анализа звонков Mango Office" Foreground="#64748B" Margin="0,8,0,0"/></StackPanel>
        <UniformGrid Grid.Row="1" Columns="3" Margin="0,28,0,24">
            <Border Background="White" CornerRadius="10" Padding="20" Margin="0,0,14,0"><StackPanel><TextBlock Text="Журнал звонков" Foreground="#64748B"/><TextBlock Text="Просматривайте и фильтруйте все звонки" FontWeight="SemiBold" FontSize="16" Margin="0,8,0,0"/></StackPanel></Border>
            <Border Background="White" CornerRadius="10" Padding="20" Margin="0,0,14,0"><StackPanel><TextBlock Text="Синхронизация" Foreground="#64748B"/><TextBlock Text="Импорт из Mango — в одном действии" FontWeight="SemiBold" FontSize="16" Margin="0,8,0,0"/></StackPanel></Border>
            <Border Background="White" CornerRadius="10" Padding="20"><StackPanel><TextBlock Text="Статистика" Foreground="#64748B"/><TextBlock Text="Отчёты по сотрудникам и группам" FontWeight="SemiBold" FontSize="16" Margin="0,8,0,0"/></StackPanel></Border>
        </UniformGrid>
        <Border Grid.Row="2" Background="White" CornerRadius="10" Padding="26"><StackPanel><TextBlock Text="С чего начать" FontSize="18" FontWeight="SemiBold"/><TextBlock Text="Откройте «Журнал звонков», чтобы увидеть данные за сегодня, или выполните импорт, чтобы получить новые звонки из Mango." TextWrapping="Wrap" Foreground="#64748B" Margin="0,10,0,0"/></StackPanel></Border>
    </Grid>
</UserControl>
