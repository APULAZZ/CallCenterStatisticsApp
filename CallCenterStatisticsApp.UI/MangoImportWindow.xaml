<Window x:Class="CallCenterStatisticsApp.UI.MangoImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Импорт из MANGO"
        Height="460"
        Width="560"
        WindowStartupLocation="CenterScreen">
	<Grid Margin="20">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<TextBlock Text="Импорт данных из MANGO"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

		<StackPanel Grid.Row="1">
			<WrapPanel Margin="0,0,0,10">
				<StackPanel Margin="0,0,15,0">
					<TextBlock Text="Дата с"/>
					<DatePicker x:Name="FromDatePicker" Width="160"/>
				</StackPanel>

				<StackPanel Margin="0,0,15,0">
					<TextBlock Text="Дата по"/>
					<DatePicker x:Name="ToDatePicker" Width="160"/>
				</StackPanel>
			</WrapPanel>

			<CheckBox x:Name="SyncEmployeesCheckBox"
                      Content="Синхронизировать сотрудников"
                      IsChecked="True"
                      Margin="0,0,0,8"/>

			<CheckBox x:Name="SyncGroupsCheckBox"
                      Content="Синхронизировать группы"
                      IsChecked="True"
                      Margin="0,0,0,8"/>

			<CheckBox x:Name="SyncTopicsCheckBox"
                      Content="Синхронизировать тематики"
                      IsChecked="True"
                      Margin="0,0,0,8"/>
		</StackPanel>

		<Border Grid.Row="2"
                Margin="0,15,0,0"
                Padding="12"
                CornerRadius="8"
                BorderThickness="1"
                BorderBrush="#D0D7E2"
                Background="#F7F9FC">
			<StackPanel>
				<TextBlock Text="Статус"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6"/>

				<TextBlock x:Name="StatusTextBlock"
                           Text="Готово."
                           TextWrapping="Wrap"
                           Foreground="DarkBlue"/>
			</StackPanel>
		</Border>

		<StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">
			<Button x:Name="BackButton"
                    Content="Назад"
                    Width="110"
                    Height="34"
                    Margin="0,0,10,0"
                    Click="BackButton_Click"/>

			<Button x:Name="ImportButton"
                    Content="Импорт"
                    Width="130"
                    Height="34"
                    Click="ImportButton_Click"/>
		</StackPanel>
	</Grid>
</Window>