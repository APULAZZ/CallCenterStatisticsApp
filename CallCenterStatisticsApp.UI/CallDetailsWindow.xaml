<Window x:Class="CallCenterStatisticsApp.UI.CallDetailsWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Карточка звонка" Width="620" Height="620" WindowStartupLocation="CenterOwner" Background="{DynamicResource AppBackground}"><Grid Margin="26"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><StackPanel><TextBlock Text="Карточка звонка" FontSize="25" FontWeight="SemiBold" Foreground="{DynamicResource AppText}"/><TextBlock x:Name="DateTextBlock" Foreground="{DynamicResource AppMutedText}" Margin="0,6,0,0"/></StackPanel><ScrollViewer Grid.Row="1" Margin="0,22,0,14"><StackPanel><Border Background="{DynamicResource AppSurface}" CornerRadius="10" Padding="20"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><TextBlock Text="Сотрудник" Foreground="{DynamicResource AppMutedText}"/><TextBlock x:Name="EmployeeTextBlock" Grid.Column="1" Foreground="{DynamicResource AppText}"/><TextBlock Text="Группа" Grid.Row="1" Foreground="{DynamicResource AppMutedText}" Margin="0,14,0,0"/><TextBlock x:Name="GroupTextBlock" Grid.Row="1" Grid.Column="1" Foreground="{DynamicResource AppText}" Margin="0,14,0,0"/><TextBlock Text="Номер" Grid.Row="2" Foreground="{DynamicResource AppMutedText}" Margin="0,14,0,0"/><TextBlock x:Name="PhoneTextBlock" Grid.Row="2" Grid.Column="1" Foreground="{DynamicResource AppText}" Margin="0,14,0,0"/><TextBlock Text="Направление" Grid.Row="3" Foreground="{DynamicResource AppMutedText}" Margin="0,14,0,0"/><TextBlock x:Name="DirectionTextBlock" Grid.Row="3" Grid.Column="1" Foreground="{DynamicResource AppText}" Margin="0,14,0,0"/><TextBlock Text="Тематика" Grid.Row="4" Foreground="{DynamicResource AppMutedText}" Margin="0,14,0,0"/><TextBlock x:Name="TopicTextBlock" Grid.Row="4" Grid.Column="1" Foreground="{DynamicResource AppText}" Margin="0,14,0,0"/><TextBlock Text="Длительность" Grid.Row="5" Foreground="{DynamicResource AppMutedText}" Margin="0,14,0,0"/><TextBlock x:Name="DurationTextBlock" Grid.Row="5" Grid.Column="1" Foreground="{DynamicResource AppText}" Margin="0,14,0,0"/></Grid></Border><Border Background="{DynamicResource AppSurface}" CornerRadius="10" Padding="20" Margin="0,16,0,0"><StackPanel><TextBlock Text="Запись разговора" FontWeight="SemiBold" FontSize="16" Foreground="{DynamicResource AppText}"/><TextBlock x:Name="RecordingTextBlock" Foreground="{DynamicResource AppMutedText}" TextWrapping="Wrap" Margin="0,10,0,0"/><MediaElement x:Name="AudioPlayer" LoadedBehavior="Manual" UnloadedBehavior="Manual" Height="0"/><StackPanel Orientation="Horizontal" Margin="0,14,0,0"><Button x:Name="PlayButton" Content="▶ Прослушать" Click="PlayButton_Click" IsEnabled="False" Padding="14,7"/><Button x:Name="DownloadButton" Content="⇩ Скачать" Click="DownloadButton_Click" IsEnabled="False" Padding="14,7" Margin="8,0,0,0"/></StackPanel></StackPanel></Border></StackPanel></ScrollViewer><Button Grid.Row="2" Content="Закрыть" Click="CloseButton_Click" Padding="18,8" HorizontalAlignment="Right"/></Grid></Window>
